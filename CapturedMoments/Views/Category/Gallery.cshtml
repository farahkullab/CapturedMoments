@model IEnumerable<Gallery>

@{
    ViewData["Title"] = "Gallery";
}

<section class="featured-contests">
    <div class="container">
        <div class="row" style="display: flex; flex-wrap: wrap; gap: 0;">
            <div class="col-lg-12" style="padding: 0;">
                <div class="section-heading text-center">
                    <h6>Featured Contests</h6>
                    <h4>View Most <em>Popular</em> Category <em>Contests</em></h4>
                </div>
            </div>
        </div>
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-lg-6 mb-4">
                    <div class="item">
                        <div class="thumb" style="width: 100%; height: auto; display: block;">
                            <img src="@item.Image" alt="">
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>   

